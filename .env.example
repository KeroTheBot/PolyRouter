# Auth for NUC -> VPS channel
POLY_API_KEY=your-secret-api-key-here

# Wallet private key (hex, with or without 0x prefix)
POLY_PRIVATE_KEY=

# Polymarket CLOB API credentials (derive via POST /api/derive-creds after setting private key)
POLY_CLOB_API_URL=https://clob.polymarket.com
POLY_CLOB_API_KEY=
POLY_CLOB_API_SECRET=
POLY_CLOB_API_PASSPHRASE=

# Chain: 137 = Polygon mainnet, 80002 = Amoy testnet
POLY_CHAIN_ID=137

# Server
POLY_HOST=0.0.0.0
POLY_PORT=8080
